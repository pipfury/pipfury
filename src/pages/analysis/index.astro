---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Card from '@/components/Card.astro';
const entries = (await getCollection('analysis', e => !e.data.draft)).sort((a,b)=>(a.data.order||99)-(b.data.order||99));
---
<BaseLayout title="Analysis" description="Educational chart case files with evidence, invalidation, and review.">
<section class="section"><div class="container"><span class="pill">PipFury</span><h1 class="mt-4 font-display text-5xl font-bold">Analysis</h1><p class="mt-4 max-w-2xl text-muted">Educational chart case files with evidence, invalidation, and review.</p><div class="mt-8 grid-auto">{entries.map(e => <Card title={e.data.title} href={'/' + e.slug + '/'} description={e.data.description} tags={e.data.tags} label={e.collection} />)}</div></div></section>
</BaseLayout>


