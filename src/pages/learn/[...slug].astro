---
import { getCollection } from 'astro:content';
import ContentLayout from '@/layouts/ContentLayout.astro';
export async function getStaticPaths() {
 const entries = await getCollection('learn', e => !e.data.draft);
 return entries.map(entry => ({ params: { slug: entry.data.slug.replace('learn/','') }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await entry.render();
---
<ContentLayout entry={entry} kicker="Learn"><Content /></ContentLayout>
