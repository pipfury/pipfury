---
import { nav } from '@/data/nav';
---
<header class="sticky top-0 z-50 border-b border-steel/90 bg-terminal/85 backdrop-blur-xl">
  <div class="container flex h-18 items-center justify-between gap-4 py-3">
    <a href="/" class="flex items-center gap-3" aria-label="PipFury home">
      <img src="/favicon.svg" alt="" width="42" height="42" />
      <span><strong class="font-display text-xl">Pip<span class="text-amber">Fury</span></strong><small class="block text-[11px] text-muted">Education only. No signals.</small></span>
    </a>
    <nav class="hidden items-center gap-6 md:flex" aria-label="Main navigation">
      {nav.map(item => <a class="text-sm font-semibold text-muted hover:text-text" href={item.href}>{item.label}</a>)}
    </nav>
    <div class="flex items-center gap-2">
      <a class="hidden rounded-full border border-steel px-3 py-2 text-sm font-semibold text-muted hover:text-text sm:inline-flex" href="/search/">Search</a>
      <a class="btn btn-primary text-sm" href="/learn/start-here/">Start Learning</a>
    </div>
  </div>
</header>
