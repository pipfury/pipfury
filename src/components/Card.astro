---
const { title, href='#', label='', description='', tags=[] } = Astro.props;
---
<a href={href} class="terminal-card card-hover block p-6">
  {label && <div class="mb-3 text-xs font-bold uppercase tracking-[.12em] text-amber">{label}</div>}
  <h3 class="font-display text-2xl font-bold text-text">{title}</h3>
  <p class="mt-3 text-sm leading-7 text-muted">{description}</p>
  <div class="mt-5 flex flex-wrap gap-2">{tags?.slice(0,4).map((t:string)=><span class="tag">{t}</span>)}</div>
</a>
