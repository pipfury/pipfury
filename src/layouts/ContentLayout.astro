---
import BaseLayout from './BaseLayout.astro';
import RiskBanner from '@/components/RiskBanner.astro';
const { entry, kicker='Evidence Desk' } = Astro.props;
const data = entry.data;
---
<BaseLayout title={data.seoTitle || data.title || data.term} description={data.seoDescription || data.description || data.definition}>
  <section class="section">
    <div class="container">
      <div class="mb-8"><a class="text-sm text-muted hover:text-amber" href="/">Home</a><span class="mx-2 text-dim">/</span><span class="text-sm text-amber">{kicker}</span></div>
      <div class="grid gap-8 lg:grid-cols-[1fr_320px]">
        <article class="terminal-card p-6 md:p-10">
          <span class="pill">{kicker}</span>
          <h1 class="mt-4 font-display text-4xl font-bold leading-tight md:text-6xl">{data.title || data.term}</h1>
          <p class="mt-5 text-lg leading-8 text-muted">{data.description || data.definition}</p>
          <div class="mt-6 flex flex-wrap gap-2">{data.tags?.map((t:string)=><span class="tag">{t}</span>)}</div>
          <div class="my-8"><RiskBanner /></div>
          <div class="prose"><slot /></div>
        </article>
        <aside class="space-y-5">
          <div class="terminal-card p-5"><h2 class="font-display text-xl font-bold">Page status</h2><p class="metric mt-3">Updated: {data.updatedAt || data.publishedAt || 'To be updated'}</p><p class="metric mt-2">Education only · No signals</p></div>
          <div class="terminal-card p-5"><h2 class="font-display text-xl font-bold">Study rule</h2><p class="mt-3 text-sm leading-7 text-muted">Read the concept, check the evidence, define invalidation, and review the outcome before drawing conclusions.</p></div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
